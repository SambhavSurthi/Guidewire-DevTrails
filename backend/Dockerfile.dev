FROM python:3.11-slim
WORKDIR /app

# Install build dependencies for asyncpg, etc.
RUN apt-get update && apt-get install -y gcc default-libmysqlclient-dev libpq-dev && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
