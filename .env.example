# GigGuard X — Environment Variables
# =====================================
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── DATABASE ──────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://gigguard:gigguard123@localhost:5432/gigguard_db

# Sync URL for Alembic migrations only
DATABASE_SYNC_URL=postgresql://gigguard:gigguard123@localhost:5432/gigguard_db

# Redis connection
REDIS_URL=redis://localhost:6379/0

# ── AUTH ──────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-256-bit-key-here-change-this

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── FREE AI APIs ──────────────────────────────────────────────────
# Google Gemini 2.0 Flash (FREE)
# Get your free API key at: https://aistudio.google.com/app/apikey
# Free tier: 15 RPM, 1M tokens/day — no credit card needed
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp

# HuggingFace Sentence Transformers — NO API KEY NEEDED
# Model downloads automatically on first run (~80MB)
# Model: sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── FREE WEATHER & ENVIRONMENT APIs ───────────────────────────────
# OpenWeatherMap (FREE)
# Sign up at: https://openweathermap.org/api
# Free tier: 1,000 calls/day, 60 calls/min
# Use "Current Weather" + "One Call API 3.0" (free with registration)
OPENWEATHERMAP_API_KEY=your_openweathermap_key_here
OPENWEATHERMAP_BASE_URL=https://api.openweathermap.org/data/2.5

# World Air Quality Index (WAQI) — FREE
# Get token at: https://aqicn.org/data-platform/token/
# Free tier: 1,000 calls/day
WAQI_API_KEY=your_waqi_api_key_here
WAQI_BASE_URL=https://api.waqi.info

# Nominatim (OpenStreetMap Geocoding) — COMPLETELY FREE, NO KEY NEEDED
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=gigguardx/1.0 (hackathon@example.com)

# ── PAYMENT (TEST MODE — FREE) ────────────────────────────────────
# Razorpay Test Mode — completely free, no real money
# Sign up at: https://razorpay.com → Dashboard → Test Mode
# Test keys start with rzp_test_
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_test_secret_here
RAZORPAY_ACCOUNT_NUMBER=your_test_account_number

# ── APP CONFIG ────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=GigGuard X
APP_VERSION=1.0.0
DEBUG=true

# URL where frontend is served
FRONTEND_URL=http://localhost:5173

# URL where backend API is served
BACKEND_URL=http://localhost:8000

# CORS — list of allowed origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:80"]

# ── CELERY ────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Monitoring interval in minutes
MONITORING_INTERVAL_MINUTES=15

# ── ML MODEL PATHS ────────────────────────────────────────────────
ML_MODELS_DIR=app/ml/models
RISK_MODEL_PATH=app/ml/models/risk_model.pkl
INCOME_MODEL_PATH=app/ml/models/income_model.pkl
FRAUD_MODEL_PATH=app/ml/models/fraud_model.pkl

# ── RAG / VECTOR STORE ────────────────────────────────────────────
RAG_KNOWLEDGE_BASE_DIR=app/rag/knowledge_base
FAISS_INDEX_PATH=app/rag/rag_index.faiss
FAISS_CHUNKS_PATH=app/rag/rag_chunks.pkl
RAG_TOP_K=5
CHAT_HISTORY_TTL_SECONDS=86400

# ── INSURANCE PARAMETERS ─────────────────────────────────────────
# Workability Score trigger threshold (auto-claim fires below this)
WS_TRIGGER_THRESHOLD=20

# Payout percentages per event type
PAYOUT_PCT_HEAVY_RAIN=60
PAYOUT_PCT_EXTREME_HEAT=40
PAYOUT_PCT_FLOOD=100
PAYOUT_PCT_SEVERE_AQI=50
PAYOUT_PCT_CURFEW=100
PAYOUT_PCT_APP_OUTAGE=30

# Trigger thresholds
TRIGGER_RAIN_MM_HR=35.0
TRIGGER_HEAT_INDEX_C=40.0
TRIGGER_AQI=300
TRIGGER_APP_UPTIME_PCT=98.0

# Wallet configuration
WALLET_PREMIUM_PCT=10
WALLET_CASHBACK_PCT=60

# Trust score thresholds
TRUST_INSTANT_APPROVE=85
TRUST_FAST_APPROVE=70
TRUST_MANUAL_REVIEW=40

# ── RATE LIMITING ─────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_CHAT_PER_MINUTE=20

# ── LOGGING ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
